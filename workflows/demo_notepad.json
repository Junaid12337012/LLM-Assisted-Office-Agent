{
  "id": "demo_notepad",
  "version": "1.0.0",
  "inputs": {
    "note_path": "data/evidence/exports/notepad_demo.txt",
    "note_content": "Phase 1 desktop demo\n\nThis file was generated by the Office Automation Platform.\nIf Notepad opened this file, your desktop command execution is working.\n"
  },
  "steps": [
    {
      "step_id": "write_demo_note",
      "action": {
        "type": "files.write_text",
        "args": {
          "path": "{note_path}",
          "content": "{note_content}"
        },
        "on_fail": {"strategy": "abort"}
      },
      "validate": [
        {
          "kind": "files.exists",
          "args": {"path": "{written_path}"},
          "on_fail": {"strategy": "abort"}
        }
      ]
    },
    {
      "step_id": "launch_notepad",
      "action": {
        "type": "desktop.launch_app",
        "args": {
          "command": "notepad.exe \"{note_path}\""
        },
        "on_fail": {"strategy": "abort"}
      },
      "validate": [
        {
          "kind": "files.exists",
          "args": {"path": "{note_path}"},
          "on_fail": {"strategy": "abort"}
        }
      ]
    }
  ],
  "success_criteria": [
    {
      "kind": "files.exists",
      "args": {"path": "{note_path}"},
      "on_fail": {"strategy": "abort"}
    }
  ]
}
