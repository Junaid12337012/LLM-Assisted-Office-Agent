{
  "id": "mvp_start_day",
  "version": "1.0.0",
  "inputs": {
    "workspace_url": "https://intranet.example.local/workspace",
    "workspace_folder": "data/evidence/exports",
    "note_path": "data/evidence/notes/start_day.md",
    "note_title": "Start Day"
  },
  "steps": [
    {
      "step_id": "write_start_note",
      "action": {
        "type": "files.write_text",
        "args": {
          "path": "{note_path}",
          "content": "Office Agent - {note_title}\nDate: {run_date}\n\nTop priorities\n- Review inbox\n- Download daily report\n- Check entries\n- Close the day with a summary\n\nWorking notes\n- \n"
        },
        "on_fail": {"strategy": "abort"}
      },
      "validate": [
        {
          "kind": "files.exists",
          "args": {"path": "{written_path}"},
          "on_fail": {"strategy": "abort"}
        }
      ]
    },
    {
      "step_id": "open_workspace_page",
      "action": {
        "type": "browser.goto",
        "args": {"url": "{workspace_url}"},
        "on_fail": {"strategy": "abort"}
      },
      "validate": [
        {
          "kind": "browser.url_matches",
          "args": {"pattern": "^https://intranet\\.example\\.local/.+"},
          "on_fail": {"strategy": "abort"}
        }
      ]
    },
    {
      "step_id": "open_workspace_folder",
      "action": {
        "type": "desktop.open_path",
        "args": {"path": "{workspace_folder}"},
        "on_fail": {"strategy": "abort"}
      },
      "validate": [
        {
          "kind": "files.exists",
          "args": {"path": "{workspace_folder}"},
          "on_fail": {"strategy": "abort"}
        }
      ]
    },
    {
      "step_id": "open_daily_note",
      "action": {
        "type": "desktop.launch_app",
        "args": {"command": "notepad.exe \"{note_path}\""},
        "on_fail": {"strategy": "abort"}
      },
      "validate": [
        {
          "kind": "files.exists",
          "args": {"path": "{note_path}"},
          "on_fail": {"strategy": "abort"}
        }
      ]
    }
  ],
  "success_criteria": [
    {
      "kind": "files.exists",
      "args": {"path": "{note_path}"},
      "on_fail": {"strategy": "abort"}
    },
    {
      "kind": "files.exists",
      "args": {"path": "{workspace_folder}"},
      "on_fail": {"strategy": "abort"}
    }
  ]
}
